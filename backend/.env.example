PORT=5001
NODE_ENV=development

# MongoDB — dev uses embedded DB on port 27018 when localhost:27017 is unavailable
MONGODB_URI=mongodb://localhost:27017/octazen_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRE=7d

# Admin Credentials (used for seeding)
ADMIN_EMAIL=admin@octazentechnologies.com
ADMIN_PASSWORD=Admin@Octazen2024!

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=contact@octazentechnologies.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Octazen Technologies <contact@octazentechnologies.com>

# Client URL
CLIENT_URL=http://localhost:5173

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
