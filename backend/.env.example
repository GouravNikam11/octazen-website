PORT=5001
NODE_ENV=development

# MongoDB — dev auto-starts embedded DB on port 27018 when local MongoDB is unavailable
MONGODB_URI=mongodb://127.0.0.1:27018/octazen_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRE=7d

# Admin Credentials (used for seeding)
ADMIN_EMAIL=admin@octazentechnologies.com
ADMIN_PASSWORD=Admin@Octazen2024!

# Email (Nodemailer) — GoDaddy: smtpout.secureserver.net, port 587
# Wrap EMAIL_PASS in quotes if it contains # or other special characters
EMAIL_HOST=smtpout.secureserver.net
EMAIL_PORT=587
EMAIL_USER=contact@octazentechnologies.com
EMAIL_PASS="your_email_password"
EMAIL_FROM="Octazen Technologies <contact@octazentechnologies.com>"
# Set to true in local dev to skip SMTP (messages still save in admin)
EMAIL_SKIP=false

# Client URL
CLIENT_URL=http://localhost:5173

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
